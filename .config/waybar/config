
{
    "layer": "top",
    "width": "90%",
    "margin-top": 0,
    "margin-bottom": 0,

    "modules-left": [
           "custom/launcher", 
           "custom/updates",
	         "custom/separator#line",
           "clock", 
	         "custom/separator#line",
           "temperature", 
           "custom/temperature-gpu", 
	         "custom/separator#line",
           "cpu", 
           "memory", 
    ],

    "modules-center": [
           "cava",
           "cava",
           "hyprland/workspaces",
    ],

    "modules-right": [
           "network", 
           "custom/separator#line",
           "pulseaudio#microphone",
           "pulseaudio", 
           "custom/separator#line",
           "battery", 
           "custom/separator#line",
           "custom/notification",
           "custom/separator#line",
           "custom/power"
    ],

    "custom/separator#line": {
        "format": "|",
        "interval": "once",
        "tooltip": false
      },


"custom/temperature-gpu": {
    "exec": "echo -e \"$(cat /sys/class/thermal/thermal_zone7/temp | awk '{printf \"%.0f\", $1/1000}')┬░C\"",
    "interval": 5,
    "format": "{} {icon}",
    "tooltip": false,
    "format-icons": "´ïë"
},
"temperature": {
    "thermal-zone": 4, 
    "critical-threshold": 80,
    "format-critical": "{temperatureC}┬░C ÔÜá´©Å",
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": "´ïë"
},

"cava": {
		"framerate": 120,
        "autosens": 1,
        "bars": 8,
        "lower_cutoff_freq": 1,
        "higher_cutoff_freq": 10000,
        "method": "pulse",
        "source": "auto",
        "stereo": true,
        "reverse": false,
        "bar_delimiter": 0,
        "monstercat": false,
        "waves": false,
        "noise_reduction": 0.5,
        "input_delay": 0,
		"hide_on_silence": false,
        "format-icons" : ["Ôûü", "Ôûé", "Ôûâ", "Ôûä", "Ôûà", "Ôûå", "Ôûç", "Ôûê" ],
        "actions": {
                   "on-click-right": "mode"
                   }
    },

"tray": {
	"icon-size": 20,
	"spacing": 4,
},



    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "´Çª {volume}%",
        "format-bluetooth": "{volume}% {icon}´èö",
        "tooltip": false,
        "scroll-step": 5,
        "on-click": "pavucontrol",
        "format-icons": {
          "headphone": "´ÇÑ",
          "hands-free": "´ûÉ",
          "headset": "´ûÉ",
          "phone": "´éò",
          "portable": "´éò",
          "car": "´å╣",
          "default": ["´Çº", "´Ç¿"]
        },    
      },
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "´ä░ {volume}%",
        "format-source-muted": "´ä▒",
        "on-click": "$HOME/.config/hypr/scripts/volume.sh --toggle-mic",
        "on-click-right": "pavucontrol -t 4",
        "on-scroll-up": "$HOME/.config/hypr/scripts/volume.sh --mic-inc",
        "on-scroll-down": "$HOME/.config/hypr/scripts/volume.sh --mic-dec",
        "tooltip-format": "{source_desc} | {source_volume}%",
        "scroll-step": 5,
    },


    "hyprland/workspaces1": {
        "disable-scroll": true,
        "on-click": "activate",
        "all-outputs": true,
        "active-only": false,
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": []
        },
        "format": "{icon}",
        "format-icons": {
            "active": "<span font='12'>¾░«»</span>",
            "empty": "<span font='8'>´äæ</span>",
            "persistent": "¾░èá"
        }
    },

    "network": {
        "tooltip": true,
        "tooltip-format": "{bandwidthUpBits} Ôåæ {bandwidthDownBits} Ôåô",
        "format-wifi": "<span color='#9ece6a'> </span> {bandwidthDownBits}",
        "format-ethernet": "<span color='#9ece6a'>¾░êÇ</span> ",
        "format-disconnected": "<span color='#f7768e'>¾░êé </span> Disconnected",
        "on-click": "nm-connection-editor",
        "interval": 30
    },

    "backlight": {
        "tooltip": false,
        "format": "´â½ {}%",
        "interval": 1,
        "on-scroll-up": "light -A 5",
        "on-scroll-down": "light -U 5"
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 10
        },
        "format": "{icon}  <span color='#F1F1F1'>{capacity}%</span>",
        "format-charging": "<span color='#9ece6a'>´çª</span> <span color='#F1F1F1'>{capacity}%</span>",
        "format-plugged": "´çª <span color='#F1F1F1'>{capacity}</span>%",
        "format-alt": "<span color='#F1F1F1'>{time}</span> {icon}",
        "format-icons": [
            "<span color='#f7768e'>´ëä</span>",
            "<span color='#e0af68'>´ëâ</span>",
            "<span color='#e0af68'>´ëé</span>",
            "<span color='#9ece6a'>´ëü</span>",
            "<span color='#9ece6a'>´ëÇ</span>"
        ]
    },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%A, %B %d, %Y (%R)}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#f5e0dc'><b>{}</b></span>",
                "days": "<span color='#cdd6f4'><b>{}</b></span>",
                "weeks": "<span color='#fab387'><b>W{}</b></span>",
                "weekdays": "<span color='#f5c2e7'><b>{}</b></span>",
                "today": "<span color='#cba6f7'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "cpu": {
        "format": "´ïø {usage}%",
        "interval": 1,
        "min-length": 5,
        "format-alt-click": "click",
        "format-alt": "¾░ìø{usage:>2}% {icon0}{icon1}{icon2}{icon3}{icon4} ",
        "format-icons": [
          "Ôûü", "Ôûé", "Ôûâ", "Ôûä", "Ôûà", "Ôûå", "Ôûç", "Ôûê"
        ],
        "on-click-right": "gnome-system-monitor",
      },

    "memory": {
      "interval": 1,
      "format": "¾░ôà {used:0.1f}G",
      "format-alt": "{percentage}% ¾░¥å",
      "format-alt-click": "click",
      "tooltip": true,
      "tooltip-format": "{used:0.1f}GB/{total:0.1f}G",
      "on-click-right": "kitty --title btop sh -c 'btop'"
    },

    "custom/launcher": {
        "format": "´îâ ",
        "on-click": "rofi -show drun",
        "on-click-right": "killall rofi"
    },

    "custom/power": {
        "format": "<span color='#f7768e'>ÔÅ╗</span>",
        "on-click": "~/Di3go0-0_dots/.config/hypr/scripts/logoutlaunch.sh"
    },

    "custom/updates": {
        "format": "{}",
        "exec": "checkupdates | wc -l",
        "exec-if": "[[ $(checkupdates | wc -l) != 0 ]]",
        "interval": 15,
        "on-click": "kitty -e sudo pacman -Syu && notify-send 'The system has been updated'"
    },

  "custom/notification": {
      "tooltip": false,
      "format": "{icon}",
      "format-icons": {
        "notification": "´éó<span foreground='red'><sup>´æä</sup></span> ",
        "none": "´éó ",
        "dnd-notification": "´çÀ<span foreground='red'><sup>´æä</sup></span> ",
        "dnd-none": "´çÀ ",
        "inhibited-notification": "´éó<span foreground='red'><sup>´æä</sup></span> ",
        "inhibited-none": "´éó ",
        "dnd-inhibited-notification": "´çÀ<span foreground='red'><sup>´æä</sup></span> ",
        "dnd-inhibited-none": "´çÀ "
      },
      "return-type": "json",
      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",
