{
    "layer": "top",
    "width": "90%",
    "margin-top": 0,
    "margin-bottom": 0,

    "modules-left": [
           "custom/launcher",
           "custom/updates",
	         "custom/separator#line",
           "clock",
	         "custom/separator#line",
           "temperature",
           "custom/temperature-gpu",
	         "custom/separator#line",
           "cpu",
           "memory",
    ],

    "modules-center": [
           "cava",
           "hyprland/workspaces",
    ],

    "modules-right": [
           "tray",
           "network",
           "custom/separator#line",
           "pulseaudio#microphone",
           "pulseaudio",
           "custom/bluetooth",
           "custom/separator#line",
           "battery",
           "custom/separator#line",
           "custom/notification",
           "custom/separator#line",
           "custom/power"
    ],

    "custom/separator#line": {
        "format": "|",
        "interval": "once",
        "tooltip": false
      },


"custom/temperature-gpu": {
    "exec": "echo -e \"$(cat /sys/class/thermal/thermal_zone7/temp | awk '{printf \"%.0f\", $1/1000}')┬░C\"",
    "interval": 5,
    "format": "{} {icon}",
    "tooltip": false,
    "format-icons": "’ŗē"
},
"temperature": {
    "thermal-zone": 4,
    "critical-threshold": 80,
    "format-critical": "{temperatureC}┬░C ŌÜĀ’ĖÅ",
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": "’ŗē"
},

"custom/bluetooth": {
    "format": "’Ŗō ",
    "return-type": "json",
    "exec": "~/.config/waybar/scripts/bluetooth.status.sh",
    "exec-if": "which bluetoothctl",
    "interval": 5,
    "on-click": "blueman-manager &",
    "tooltip": true
},

"cava": {
		"framerate": 120,
        "autosens": 1,
        "bars": 8,
        "lower_cutoff_freq": 1,
        "higher_cutoff_freq": 10000,
        "method": "pulse",
        "source": "auto",
        "stereo": true,
        "reverse": false,
        "bar_delimiter": 0,
        "monstercat": false,
        "waves": false,
        "noise_reduction": 0.5,
        "input_delay": 0,
		"hide_on_silence": false,
        "format-icons" : ["Ō¢ü", "Ō¢é", "Ō¢ā", "Ō¢ä", "Ō¢ģ", "Ō¢å", "Ō¢ć", "Ō¢ł" ],
        "actions": {
                   "on-click-right": "mode"
                   }
    },

"tray": {
	"icon-size": 20,
	"spacing": 4,
},



    "pulseaudio": {
        "format": "{volume}% {icon} ",
        "format-muted": "’Ć” {volume}%",
        "format-bluetooth": "{volume}% {icon} ’Ŗö",
        "tooltip": false,
        "scroll-step": 5,
        "on-click": "pavucontrol",
        "format-icons": {
          "headphone": "’Ćź",
          "hands-free": "’Ćź",
          "headset": "’Ćź",
          "phone": "’éĢ",
          "portable": "’éĢ",
          "car": "’å╣",
          "default": ["’Ć¦", "’Ć©"]
        },
      },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "’ä░ {volume}%",
        "format-source-muted": "’ä▒",
        "on-click": "$HOME/.config/hypr/scripts/volume.sh --toggle-mic",
        "on-click-right": "pavucontrol -t 4",
        "on-scroll-up": "$HOME/.config/hypr/scripts/volume.sh --mic-inc",
        "on-scroll-down": "$HOME/.config/hypr/scripts/volume.sh --mic-dec",
        "tooltip-format": "{source_desc} | {source_volume}%",
        "scroll-step": 5,
    },


    "hyprland/workspaces1": {
        "disable-scroll": true,
        "on-click": "activate",
        "all-outputs": true,
        "active-only": false,
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": []
        },
        "format": "{icon}",
        "format-icons": {
            "active": "<span font='12'>¾░«»</span>",
            "empty": "<span font='8'>’äæ</span>",
            "persistent": "¾░ŖĀ"
        }
    },

    "network": {
        "tooltip": true,
        "tooltip-format": "{ipaddr}/{cidr} ",
        "format-wifi": "<span color='#9ece6a'>¾░¢® </span> {essid}",
        "format-ethernet": "<span color='#9ece6a'>¾░łü</span> {ifname}",
        "format-disconnected": "<span color='#f7768e'>¾░łé </span> Disconnected",
        "on-click": "kitty nmtui",
        "interval": 30
    },

    "backlight": {
        "tooltip": false,
        "format": "’ā½ {}%",
        "interval": 1,
        "on-scroll-up": "light -A 5",
        "on-scroll-down": "light -U 5"
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 10
        },
        "format": "{icon}  <span color='#F1F1F1'>{capacity}%</span>",
        "format-charging": "<span color='#9ece6a'>’ć”</span> <span color='#F1F1F1'>{capacity}%</span>",
        "format-plugged": "’ć” <span color='#F1F1F1'>{capacity}</span>%",
        "format-alt": "<span color='#F1F1F1'>{time}</span> {icon}",
        "format-icons": [
            "<span color='#f7768e'>’ēä</span>",
            "<span color='#e0af68'>’ēā</span>",
            "<span color='#e0af68'>’ēé</span>",
            "<span color='#9ece6a'>’ēü</span>",
            "<span color='#9ece6a'>’ēĆ</span>"
        ]
    },

    "clock": {
        "format": "{:%d/%m ŌĆó %H:%M}",
        "format-alt": "{:%A, %B %d, %Y (%R)}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#f5e0dc'><b>{}</b></span>",
                "days": "<span color='#cdd6f4'><b>{}</b></span>",
                "weeks": "<span color='#fab387'><b>W{}</b></span>",
                "weekdays": "<span color='#f5c2e7'><b>{}</b></span>",
                "today": "<span color='#cba6f7'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    "cpu": {
        "format": "’ŗø {usage}%",
        "interval": 3,
        "min-length": 5,
        "format-alt-click": "click",
        "format-alt": "¾░Źø {usage:>2}% {icon0}{icon1}{icon2}{icon3}{icon4} ",
        "format-icons": [
          "Ō¢ü", "Ō¢é", "Ō¢ā", "Ō¢ä", "Ō¢ģ", "Ō¢å", "Ō¢ć", "Ō¢ł"
        ],
        "on-click-right": "gnome-system-monitor",
      },

    "memory": {
      "interval": 3,
      "format": "¾░ōģ {used:0.1f}G",
      "format-alt": "{percentage}% ¾░Šå",
      "format-alt-click": "click",
      "tooltip": true,
      "tooltip-format": "{used:0.1f}GB/{total:0.1f}G",
      "on-click-right": "kitty --title btop sh -c 'btop'"
    },

    "custom/launcher": {
        "format": "’īā ",
        "on-click": "rofi -show drun",
        "on-click-right": "killall rofi"
    },

    "custom/power": {
        "format": "<span color='#f7768e'>ŌÅ╗</span>",
        "on-click": "$HOME/.config/hypr/scripts/logoutlaunch.sh"
    },

    "custom/updates": {
        "format": "{}",
        "exec": "checkupdates | wc -l",
        "exec-if": "[[ $(checkupdates | wc -l) != 0 ]]",
        "interval": 15,
        "on-click": "kitty -e sudo pacman -Syu && notify-send 'The system has been updated'"
    },

  "custom/notification": {
      "tooltip": false,
      "format": "{icon}",
      "format-icons": {
        "notification": "’éó<span foreground='red'><sup>’æä</sup></span> ",
        "none": "’éó ",
        "dnd-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span> ",
        "dnd-none": "’ćĘ ",
        "inhibited-notification": "’éó<span foreground='red'><sup>’æä</sup></span> ",
        "inhibited-none": "’éó ",
        "dnd-inhibited-notification": "’ćĘ<span foreground='red'><sup>’æä</sup></span> ",
        "dnd-inhibited-none": "’ćĘ "
      },
      "return-type": "json",
      "exec-if": "which swaync-client",
      "exec": "swaync-client -swb",
      "on-click": "swaync-client -t -sw",
      "on-click-right": "swaync-client -d -sw",
      "escape": true
  },
}
